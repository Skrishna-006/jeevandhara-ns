# ========================================
# JeevanDhara Environment Configuration
# ========================================
# 
# This file contains sensitive credentials.
# IMPORTANT: Never commit this file to version control!
# Add .env to your .gitignore file
# 
# ========================================
# SMTP Configuration for Email Sending
# ========================================

# Email Provider Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# For Gmail:
# 1. Enable 2-factor authentication on your Google Account
# 2. Generate an App Password: https://apppasswords.google.com
# 3. Select "Mail" and "Windows Computer" (or your OS)
# 4. Use the 16-character password generated below

EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Default sender email (usually same as EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ========================================
# AI Configuration (JeevanDhara AI)
# ========================================

# Google Generative AI (Gemini) API Keys
# Get your keys from: https://aistudio.google.com/apikey

GEMINI_API_KEY_text_extractor=your-gemini-api-key-here
GEMINI_API_KEY_llm_analysis=your-gemini-api-key-here

# ========================================
# Alternative Email Providers
# ========================================

# SendGrid Example:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.xxxxxxxxxx-your-sendgrid-key
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# AWS SES Example:
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Office 365 / Outlook Example:
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-password
# DEFAULT_FROM_EMAIL=your-email@outlook.com
